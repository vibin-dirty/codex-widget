# Safe template for Compose interpolation values.
# Copy to a local, uncommitted env file (for example: .env) if overrides are needed.

# Compose project name (used for resource names and network labels).
COMPOSE_PROJECT_NAME=codex-widget

# Host path with codex-profiles/status data expected by CodexWidget.Web.
# Must point to trusted codex-profiles-managed data.
CODEX_WIDGET_DATA_DIR=/srv/data/codex-widget
